rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /vault/v1 {
      allow read, write: if request.auth != null;
      match /cards/{cardId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update: if request.auth != null && (resource.data.userId == request.auth.uid || !('userId' in resource.data) || resource.data.userId == "");
        allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || !('userId' in resource.data) || resource.data.userId == "");
      }
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
